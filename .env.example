# backend/app/config.py 의 전 항목. 복사해서 backend/.env 로 사용.
# 시크릿은 절대 커밋하지 말 것 (CLAUDE.md 규칙 10).

# --- DB (로컬 개발: docker-compose.dev.yml 기준) ---
# Supabase 배포 시 session pooler(5432) URL 로 교체
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/reviewdb

# --- 인증 ---
SUPABASE_JWT_SECRET=dev-jwt-secret-change-me

# --- LLM (Google Gemini 무료 티어) ---
# https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=AIzaxxxxxxxx
# 모델명은 만료된다(2026-07: gemini-2.5-flash 신규 제공 중단, 2.0-flash 쿼터 소진 잦음).
# 사용 가능 목록: https://generativelanguage.googleapis.com/v1beta/models?key=<KEY>
LLM_MODEL_CLASSIFY=gemini-3.5-flash-lite
LLM_MODEL_GENERATE=gemini-3.5-flash

# --- 내부 API 보호 (/internal/*) ---
INTERNAL_API_KEY=dev-internal-key-change-me

# --- 카카오 (P3부터 사용, 미설정 가능) ---
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=

# --- 웹푸시 VAPID (P3부터 사용, 미설정 가능) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- 크롤러 스냅샷 저장 경로 ---
SNAPSHOT_DIR=/data/snapshots
